{
  "name": "pcscanfix",
  "version": "1.0.0",
  "description": "Cross-platform PC cleanup, optimization, and security scanner",
  "author": "PCScanFix",
  "main": "electron.cjs",
  "scripts": {
    "dev": "concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "prebuild": "node scripts/generate-icon.cjs",
    "build": "vite build",
    "dist:mac": "npm run build && electron-builder --mac --x64 && electron-builder --mac --arm64",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "dist:all": "npm run build && electron-builder --mac --x64 && electron-builder --mac --arm64 && electron-builder --win --linux"
  },
  "dependencies": {},
  "devDependencies": {
    "@vitejs/plugin-react": "^4.2.1",
    "concurrently": "^8.2.2",
    "electron": "^29.1.0",
    "electron-builder": "^24.13.3",
    "lucide-react": "^0.358.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.22.0",
    "vite": "^5.1.4",
    "wait-on": "^7.2.0"
  }
}
