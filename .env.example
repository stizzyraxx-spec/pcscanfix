# Copy to .env.local and fill in real values. .env.local is gitignored.

# Stripe — dashboard.stripe.com/apikeys + dashboard.stripe.com/webhooks
STRIPE_SECRET_KEY=sk_live_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_xxx
STRIPE_PRICE_ID=price_xxx

# Public URL (Stripe redirects + Electron license check target)
PUBLIC_URL=https://pcfixscan.com

# Vercel Postgres — connect integration in Vercel dashboard, values auto-inject
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=

# Resend — resend.com/api-keys
RESEND_API_KEY=re_xxx
RESEND_FROM_EMAIL=PCFixScan <noreply@pcfixscan.com>

# Auth (generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))")
AUTH_SECRET=replace_me_with_random_96_hex_chars

# Admin panel — used for /admin login at pcfixscan.com/admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=set_a_strong_password
